classDiagram
    class Preferences {
        +String reminderTime
    }

    class Owner {
        +String name
        +Preferences preferences
        +Pet[] pets
        +addPet(pet: Pet) void
    }

    class Pet {
        +String name
        +int age
        +String breed
        +Species species
    }

    class Species {
        <<enumeration>>
        Cat
        Dog
        Other
    }

    class Task {
        +String title
        +int durationMinutes
        +DateTime time
        +Priority priority
        +Status status
        +Pet pet
    }

    class Priority {
        <<enumeration>>
        High
        Medium
        Low
    }

    class Status {
        <<enumeration>>
        Pending
        Completed
        Skipped
    }

    class Schedule {
        +Task[] tasks
        +String description
    }

    class PetCareService {
        <<singleton>>
        -tasks : List~Task~
        +getInstance() PetCareService
        +addTask(task: Task) void
        +removeTask(task: Task) void
        +updateTask(task: Task) void
        +getTasksForPet(pet: Pet) List
        +generateSchedule() Schedule
        +filterTasksByStatus(status: Status) List
        +filterTasksByPriority(priority: Priority) List
    }

    Owner "1" --> "1" Preferences : has
    Owner "1" --> "1..*" Pet : owns
    Pet --> Species : is
    Task --> Pet : assigned to
    Task --> Priority : has
    Task --> Status : has
    Schedule "1" --> "0..*" Task : contains
    PetCareService ..> Schedule : generates
    PetCareService ..> Task : manages

    